# Smart-extraction LLM (Gemini free tier — https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here
# Optional: override the model (default gemini-3.1-flash-lite)
# LLM_MODEL=gemini-3.1-flash-lite

# Resume tailoring LLM — OpenAI-compatible endpoint. Default is local Ollama.
# Swap to Groq/OpenRouter/etc. by changing these three values.
TAILOR_BASE_URL=http://localhost:11434/v1
TAILOR_API_KEY=ollama
TAILOR_MODEL=qwen3:8b

# Where tailored resume PDFs are saved (default: output/resumes inside the project)
# RESUME_OUTPUT_DIR=E:\Jobs\AI Resumes\Jobsaver Resumes

# LaTeX engine for resume compile: pdflatex (default, MiKTeX/TeX Live) or tectonic
# RESUME_LATEX_ENGINE=pdflatex

# Postgres connection (matches docker-compose.yml). Run `docker compose up -d` first.
DATABASE_URL=postgresql://jobsaver:jobsaver@localhost:5432/jobsaver
